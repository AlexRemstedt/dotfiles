#!/usr/bin/env bash
# fdtodo - Author: Alex Remstedt
#
# This script aims to recursively move look for TODO.md files based on the cwd
# It will start by looking at the cwd and then recursively move up the path
# If it finds the todo file it will open it in a new tmux window
# else it will create a new one at the present working directory

try_todo_file() {
  local dir="$1"
  # Break the recursion if we have reached the home directory
  if [[ "$dir" == "$HOME" ]]; then
    echo "Reached home directory, no TODO.md file found."
    return 1
  fi

  # Try for todo.md in the current directory
  local todo_path="$dir/todo.md"
  if [[ -f $todo_path ]]; then
    tmux neww -n todo "nvim \"$todo_path\""
    return 0
  else
    parent_dir=$(dirname "$dir")
    try_todo_file "$parent_dir"
  fi
}

try_todo_file "$PWD"
